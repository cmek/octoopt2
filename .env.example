# GivEnergy inverter (local Modbus TCP)
GIVENERGY_HOST=192.168.1.x
GIVENERGY_PORT=8899
GIVENERGY_NUMBER_BATTERIES=1
MAX_EXPORT_KW=3.6      # inverter max AC export
MAX_IMPORT_KW=11.0     # consumer unit max import

# Domestic hot water (Mitsubishi Ecodan)
DHW_POWER_KW=1.5       # heat pump power draw in DHW mode
DHW_MIN_SLOTS_PER_DAY=4  # minimum 30-min slots per day (2 hours)
DHW_MAX_SLOTS_PER_DAY=8  # maximum 30-min slots per day (4 hours)

# Octopus Energy
OCTOPUS_API_KEY=sk_live_xxxx
OCTOPUS_ACCOUNT_NUMBER=A-XXXXXXXX
OCTOPUS_MPAN=xxxx                  # electricity meter point
OCTOPUS_SERIAL=xxxx                # electricity meter serial
OCTOPUS_AGILE_PRODUCT_CODE=AGILE-24-10-01
OCTOPUS_AGILE_TARIFF_CODE=E-1R-AGILE-24-10-01-C   # buy tariff
OCTOPUS_OUTGOING_PRODUCT_CODE=OUTGOING-LITE-FIX-12M-23-09-12
OCTOPUS_OUTGOING_TARIFF_CODE=E-1R-OUTGOING-LITE-FIX-12M-23-09-12-C  # sell tariff
OCTOPUS_DNO_REGION=C               # DNO region letter (A-P)

# Solcast
SOLCAST_API_KEY=xxxx
SOLCAST_RESOURCE_ID=xxxx           # your rooftop resource ID

# Mitsubishi Ecodan (MELCloud)
MELCLOUD_EMAIL=you@example.com
MELCLOUD_PASSWORD=xxxx
MELCLOUD_DEVICE_ID=xxxx            # numeric device ID from MELCloud

# Location (used for Open-Meteo weather forecast)
LATITUDE=51.5
LONGITUDE=-0.1

# Database
DB_PATH=octoopt2.db
